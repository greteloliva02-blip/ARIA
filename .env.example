TELEGRAM_TOKEN=
TELEGRAM_USER_ID=
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Optional Firebase (skip if empty)
FIREBASE_PROJECT_ID=
FIREBASE_CRED_PATH=

# Minimal mode (default true)
ARIA_MINIMAL=true
DISABLE_CHROMA=true

# Google Gmail + Calendar (local: use google_credentials/ after auth_google.py)
# GOOGLE_CREDENTIALS_DIR=C:\ARIA\google_credentials
# Railway: set GOOGLE_TOKEN_JSON and optionally GOOGLE_CLIENT_SECRET_JSON
# DISABLE_GOOGLE=true
